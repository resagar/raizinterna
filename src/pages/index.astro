---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedMemorias, postUrl, getMetadataLabel } from '../utils/posts';

const memorias = await getPublishedMemorias();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Raíz Interna',
  url: 'https://raizinterna.xyz',
  description:
    'Memorias de criar y pensar en voz alta. Historias de un padre neurodivergente (TDAH + AACC) sobre la crianza, la escritura y la vida en bruto.',
  inLanguage: 'es',
  author: {
    '@id': 'https://raizinterna.xyz/autor#person',
  },
};
---
<BaseLayout
  title="Raíz Interna — memorias de criar y pensar en voz alta"
  description="Memorias de criar y pensar en voz alta. Historias de un padre neurodivergente (TDAH + AACC) sobre la crianza, la escritura y la vida en bruto."
  ogImage="/og/home.png"
  ogImageAlt="Raíz Interna — memorias de criar y pensar en voz alta"
  ogType="website"
>
  <Fragment slot="json-ld">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Fragment slot="content">
    <main aria-label="Memorias" class="max-w-[680px] mx-auto px-6">
      <header class="py-16 text-center">
        <h1 class="font-label uppercase text-sm text-muted tracking-[0.2em]">
          Historias reales de paternidad y mente intensa
        </h1>
      </header>

      {memorias.length === 0 ? (
        <p class="text-center text-umber italic pb-16">Pronto habrá memorias acá.</p>
      ) : (
        <ol class="list-none pl-0 pb-20">
          {memorias.map((m, i) => {
            const metadataLabel = getMetadataLabel(m);
            return (
              <li>
                <article class="flex flex-col items-center text-center">
                  <p class="font-body italic text-[18px] text-gold mb-2">
                    {metadataLabel}
                  </p>
                  <h2 class="font-display text-[22px] text-ink mb-4 leading-tight font-normal">
                    {m.data.title}
                  </h2>
                  {m.data.summary && (
                    <p class="font-body italic text-umber text-[18px] max-w-[540px] mb-6 excerpt-quoted">
                      {m.data.summary}
                    </p>
                  )}
                  <a
                    href={postUrl(m)}
                    class="font-label uppercase text-xs tracking-[0.1em] text-gold hover:opacity-70 transition-opacity"
                  >
                    Leer →
                  </a>
                </article>
                {i < memorias.length - 1 && (
                  <hr class="my-16" />
                )}
              </li>
            );
          })}
        </ol>
      )}
    </main>
  </Fragment>
</BaseLayout>
