---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getPublishedMemorias, postUrl, getMetadataLabel } from '../utils/posts';

const memorias = await getPublishedMemorias();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Raíz Interna',
  url: 'https://raizinterna.resagar.com',
  description:
    'Memorias de criar y pensar en voz alta. Historias de un padre neurodivergente (TDAH + AACC) sobre la crianza, la escritura y la vida en bruto.',
  inLanguage: 'es',
  author: {
    '@id': 'https://raizinterna.resagar.com/autor#person',
  },
};
---
<BaseLayout
  title="Raíz Interna — memorias de criar y pensar en voz alta"
  description="Memorias de criar y pensar en voz alta. Historias de un padre neurodivergente (TDAH + AACC) sobre la crianza, la escritura y la vida en bruto."
  ogImage="/og/home.png"
  ogImageAlt="Raíz Interna — memorias de criar y pensar en voz alta"
  ogType="website"
>
  <Fragment slot="json-ld">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Fragment slot="content">
    <section class="max-w-[680px] mx-auto px-6">
      <header class="py-16 text-center">
        <p class="font-label uppercase text-xs text-muted tracking-[0.2em]">
          Historias reales de paternidad y mente intensa
        </p>
      </header>

      {memorias.length === 0 ? (
        <p class="text-center text-umber italic pb-16">Pronto habrá memorias acá.</p>
      ) : (
        <div class="pb-20">
          {memorias.map((m, i) => {
            const metadataLabel = getMetadataLabel(m);
            return (
              <>
                <article class="flex flex-col items-center text-center">
                  <span class="font-body italic text-[18px] text-gold mb-2">
                    {metadataLabel}
                  </span>
                  <h3 class="font-display text-[22px] text-ink mb-4 leading-tight font-normal">
                    {m.data.title}
                  </h3>
                  {m.data.summary && (
                    <p class="font-body italic text-umber text-[18px] max-w-[540px] mb-6 excerpt-quoted">
                      {m.data.summary}
                    </p>
                  )}
                  <a
                    href={postUrl(m)}
                    class="font-label uppercase text-xs tracking-[0.1em] text-gold hover:opacity-70 transition-opacity no-underline hover:no-underline"
                  >
                    Leer →
                  </a>
                </article>
                {i < memorias.length - 1 && (
                  <div class="w-1/2 mx-auto border-t border-line-soft my-16"></div>
                )}
              </>
            );
          })}
        </div>
      )}
    </section>
  </Fragment>

  <Fragment slot="footer">
    <Footer
      copyright="© 2024 RAÍZ INTERNA. Una publicación dedicada a lo lento."
      links={[
        { label: 'Sobre Nosotros', href: '#' },
        { label: 'Newsletter', href: '#' },
      ]}
    />
  </Fragment>
</BaseLayout>
