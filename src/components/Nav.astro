---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const links = [
  { href: '/', label: 'Memorias' },
];

const linkClass = (href: string) => {
  const isActive = href === '/' ? isHome : currentPath === href;
  return isActive
    ? 'text-gold font-bold'
    : 'text-gold hover:underline underline-offset-4 transition-all';
};
---
<header class="w-full bg-ivory">
  <div class="flex flex-col items-center md:flex-row md:justify-between md:items-center w-full max-w-[680px] mx-auto px-6 py-5 gap-4 md:gap-0">
    <a
      href="/"
      class="font-logo font-light text-2xl md:text-3xl text-gold tracking-[0.15em] uppercase whitespace-nowrap"
    >
      Raíz Interna
    </a>
    <nav class="flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'font-label uppercase text-xs tracking-[0.1em]',
            linkClass(link.href),
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
  <div class="border-t border-line-soft w-3/4 md:max-w-[720px] mx-auto"></div>
</header>
