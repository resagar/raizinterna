---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const links = [
  { href: '/', label: 'Crónicas' },
  { href: '#', label: 'Archivo' },
];

const linkClass = (href: string) => {
  const isActive = href === '/' ? isHome : currentPath === href;
  return isActive
    ? 'text-ink font-bold border-b-2 border-ink pb-1'
    : 'text-muted hover:text-ink transition-colors';
};
---
<header class="w-full bg-ivory border-b border-line-soft">
  <div class="flex flex-col md:flex-row justify-between items-center w-full max-w-[680px] mx-auto px-6 py-8">
    <a
      href="/"
      class="font-logo font-light text-[32px] md:text-[48px] text-ink tracking-[0.25em] uppercase no-underline hover:no-underline"
    >
      Raíz Interna
    </a>
    <nav class="hidden md:flex items-center gap-8 mt-4 md:mt-0">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'font-label uppercase text-xs tracking-[0.1em] no-underline hover:no-underline',
            linkClass(link.href),
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <button
      type="button"
      class="md:hidden text-ink mt-4 md:mt-0"
      aria-label="Abrir menú de navegación"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-6 h-6"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>
