---
const links = [
  { label: 'Sobre el autor', href: '/autor' },
];
---
<footer class="w-full bg-ivory pt-12 pb-12">
  <div class="border-t border-line-soft w-1/2 mx-auto"></div>
  <div class="flex flex-col items-center justify-center max-w-[680px] mx-auto px-6 text-center mt-8 space-y-4">
    <p class="font-body text-base text-muted text-center">
      © 2024 RAÍZ INTERNA. Una publicación dedicada a lo lento.
    </p>
    <div class="flex items-center gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="font-label uppercase text-xs tracking-[0.1em] text-gold hover:text-ink hover:underline underline-offset-4 transition-all"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
